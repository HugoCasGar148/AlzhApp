<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alzhapp_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_principal"
        android:textColor="@color/alzhapp_primary_dark"
        android:textSize="42sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnAjustes"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/descripcion_ajustes"
        android:src="@android:drawable/ic_menu_preferences"
        app:layout_constraintBottom_toBottomOf="@id/tvTitulo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTitulo"
        app:tint="@color/alzhapp_muted" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/subtitulo_inicio"
        android:textColor="@color/alzhapp_muted"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnModuloImagenes"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginTop="32dp"
        android:text="@string/modulo_imagenes"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="@color/alzhapp_primary"
        app:cornerRadius="16dp"
        app:elevation="6dp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="36dp"
        app:iconTint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitulo" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnModuloPalabras"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginTop="20dp"
        android:text="@string/modulo_palabras"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="@color/alzhapp_primary"
        app:cornerRadius="16dp"
        app:elevation="6dp"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="36dp"
        app:iconTint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnModuloImagenes" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnModuloAsociacion"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginTop="20dp"
        android:text="@string/modulo_asociacion"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="@color/alzhapp_primary"
        app:cornerRadius="16dp"
        app:elevation="6dp"
        app:icon="@android:drawable/ic_menu_share"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="36dp"
        app:iconTint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnModuloPalabras" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHistorial"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="@string/ver_historial"
        android:textColor="@color/alzhapp_text"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/alzhapp_secondary"
        app:cornerRadius="16dp"
        app:elevation="2dp"
        app:icon="@android:drawable/ic_menu_recent_history"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="28dp"
        app:iconTint="@color/alzhapp_text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

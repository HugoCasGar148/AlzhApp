<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootImagenes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alzhapp_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/modulo_imagenes"
            android:textColor="@color/alzhapp_primary_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContadorImagenes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/alzhapp_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/elige_imagen"
            android:textColor="@color/alzhapp_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageViewObjetivo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/descripcion_imagen_objetivo"
            android:padding="16dp"
            app:tint="@color/alzhapp_primary_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImagenOpcion1"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:textSize="20sp"
            app:backgroundTint="@color/alzhapp_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImagenOpcion2"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:textSize="20sp"
            app:backgroundTint="@color/alzhapp_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImagenOpcion3"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:textSize="20sp"
            app:backgroundTint="@color/alzhapp_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImagenOpcion4"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:textSize="20sp"
            app:backgroundTint="@color/alzhapp_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolverImagenes"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="@string/volver"
            android:textColor="@color/alzhapp_text"
            android:textSize="18sp"
            app:backgroundTint="@color/alzhapp_secondary" />
    </LinearLayout>
</ScrollView>

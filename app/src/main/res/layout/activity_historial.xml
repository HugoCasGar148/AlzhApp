<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootHistorial"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/alzhapp_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/historial"
        android:textColor="@color/alzhapp_primary_dark"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/filtro_modulo"
        android:textColor="@color/alzhapp_text"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerFiltroHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvHistorialVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/sin_resultados"
        android:textColor="@color/alzhapp_muted"
        android:textSize="18sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listViewHistorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:dividerHeight="10dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolverHistorial"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/volver"
        android:textColor="@color/alzhapp_text"
        android:textSize="18sp"
        app:backgroundTint="@color/alzhapp_secondary" />

</LinearLayout>

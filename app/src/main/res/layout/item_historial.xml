<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/alzhapp_secondary"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvHistorialModulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/alzhapp_primary_dark"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistorialFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/alzhapp_muted"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvHistorialDatos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/alzhapp_text"
        android:textSize="18sp" />

</LinearLayout>
